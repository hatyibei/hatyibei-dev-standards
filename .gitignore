# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Environment
.env
.env.*
!.env.example

# Node
node_modules/

# Memory (個人の記憶はリポジトリに入れない。構造の .gitkeep のみ追跡)
.harness/memory/inbox/*.md
.harness/memory/daily/*.md
.harness/memory/summaries/*.md
.harness/memory/domains/**/*.md
.harness/memory/compost/*.md

# Search index (FTS5, tear-down & rebuild なので追跡不要)
.harness/memory/.index/

# Skill generation candidates (未検証、人間レビュー前は追跡しない)
skills/_generated/.candidates/
skills/_generated/*/

# Plans (draft は追跡しない、active/executed のみ)
plans/*.draft.md
